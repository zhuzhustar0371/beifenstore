<view class="page">
  <view wx:if="{{scene === 'order' && hasPreferredAddress && !showAddressForm}}" class="preferred-address card">
    <view class="preferred-address__header">
      <text class="preferred-address__title">已保存收货地址</text>
      <text class="preferred-address__action" bindtap="toggleAddressEditor">修改地址</text>
    </view>
    <view class="preferred-address__name-row">
      <text class="preferred-address__name">{{form.name}}</text>
      <text class="preferred-address__phone">{{form.phone}}</text>
    </view>
    <text class="preferred-address__detail">{{form.regionText}}{{form.detail}}</text>
    <view wx:if="{{isRemoteRegion}}" class="shipping-notice">
      当前地区需加收运费¥{{shippingFeeText}}，且运费不参与返现
    </view>
  </view>

  <view wx:if="{{showAddressForm || scene !== 'order' || !hasPreferredAddress}}" class="form card">
    <view class="form-item">
      <text class="label">收货人</text>
      <input class="input" placeholder="请输入姓名" value="{{form.name}}" bindinput="onName" />
    </view>

    <view class="form-item">
      <text class="label">手机号</text>
      <input class="input" type="number" placeholder="请输入手机号" value="{{form.phone}}" bindinput="onPhone" />
    </view>

    <picker mode="region" value="{{form.regionParts}}" bindchange="onRegionChange">
      <view class="form-item picker-item">
        <text class="label">所在地区</text>
        <text class="value {{form.regionText ? '' : 'placeholder'}}">
          {{form.regionText || '请选择省市区'}}
        </text>
        <text class="arrow">></text>
      </view>
    </picker>

    <view class="form-item textarea-item">
      <text class="label">详细地址</text>
      <textarea
        class="textarea"
        placeholder="街道、楼栋、门牌等"
        value="{{form.detail}}"
        bindinput="onDetail"
      />
    </view>

    <view class="form-item row">
      <text class="label">设为默认地址</text>
      <switch checked="{{form.isDefault}}" bindchange="onDefaultChange" color="#07c160" />
    </view>

    <view wx:if="{{scene === 'order' && isRemoteRegion}}" class="shipping-notice">
      当前地区需加收运费¥{{shippingFeeText}}，且运费不参与返现
    </view>
  </view>

  <view class="footer">
    <button class="btn-save btn-primary" loading="{{submitting}}" disabled="{{submitting}}" bindtap="save">
      {{scene === 'order' ? (hasPreferredAddress && !showAddressForm ? '确认并支付' : '保存并支付') : '保存'}}
    </button>
  </view>
</view>
