flowchart TD
    A["开始：进入后台用户管理"] --> B["请求 GET /admin/users"]
    B --> C{"是否存在 session.user"}
    C -- 否 --> D["重定向到 /login"]
    C -- 是 --> E{"当前角色是否为 admin"}
    E -- 否 --> F["拒绝访问，跳转到角色首页"]
    E -- 是 --> G["读取 users 与 listings 集合"]

    G --> H["按 status/role/keyword 过滤并分页"]
    H --> I["渲染 users/index.ejs 用户管理页"]

    I --> J{"管理员选择操作"}

    J --> K["禁用用户 POST /admin/users/:id/disable"]
    K --> K1["更新 users.status = disabled"]
    K1 --> K2["写入 admin_actions: disable"]
    K2 --> I

    J --> L["恢复用户 POST /admin/users/:id/enable"]
    L --> L1["更新 users.status = active"]
    L1 --> L2["写入 admin_actions: enable"]
    L2 --> I

    J --> M["设为客服 POST /admin/users/:id/make-service"]
    M --> M1{"目标用户是否存在"}
    M1 -- 否 --> I
    M1 -- 是 --> M2["更新 role = customer_service, status = active"]
    M2 --> M3["若缺失则补齐 openid/open_id/username/account"]
    M3 --> M4["写入 admin_actions: make_service"]
    M4 --> I

    J --> N["移除客服 POST /admin/users/:id/remove-service"]
    N --> N1["更新 role = user"]
    N1 --> N2["写入 admin_actions: remove_service"]
    N2 --> I

    J --> O["重置密码 POST /admin/users/:id/reset-password"]
    O --> O1{"当前操作者角色是否为 admin"}
    O1 -- 否 --> OX["返回 403"]
    O1 -- 是 --> O2{"新密码长度是否 >= 6"}
    O2 -- 否 --> OY["返回 400"]
    O2 -- 是 --> O3{"目标用户是否存在"}
    O3 -- 否 --> OZ["返回 404"]
    O3 -- 是 --> O4["生成 password_hash 与 password_salt"]
    O4 --> O5["使用 set 写回用户文档并更新时间"]
    O5 --> O6["写入 admin_actions: reset_password"]
    O6 --> I
