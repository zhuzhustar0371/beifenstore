sequenceDiagram
    autonumber
    participant U as 用户
    participant H as H5前端
    participant A as 后端API
    participant D as 数据库

    U->>H: 输入账号密码
    H->>A: POST /auth/login
    A->>D: 查找用户
    
    alt 用户不存在
        D-->>A: null
        A-->>H: 账号不存在
        H-->>U: 提示错误
    else 用户存在
        D-->>A: 用户数据
        alt 账号禁用
            A-->>H: 账号已禁用
        else 有password_hash
            A->>A: 验证密码
            alt 密码正确
                A->>A: 生成JWT
                A-->>H: 返回Token
                H-->>U: 登录成功
            else 密码错误
                A-->>H: 密码错误
            end
        else 无password_hash
            alt 默认密码
                A->>D: 创建password_hash
                A-->>H: 返回Token
            else 非默认密码
                A-->>H: 请用默认密码
            end
        end
    end
