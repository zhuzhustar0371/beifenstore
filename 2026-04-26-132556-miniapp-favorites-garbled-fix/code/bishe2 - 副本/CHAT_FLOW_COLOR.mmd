flowchart TB
    subgraph 用户端["🎨 用户端"]
        U1(["👤 用户A"])
        HA["📱 H5前端A"]
        U2(["👤 用户B"])
        HB["📱 H5前端B"]
    end

    subgraph 服务端["⚙️ 服务端"]
        API["🌐 REST API"]
        WS["🔌 WebSocket服务"]
    end

    subgraph 数据层["💾 数据层"]
        DB[("🗄️ 数据库")]
    end

    %% 样式定义
    classDef user fill:#e1f5fe,stroke:#01579b,stroke-width:2px,color:#000
    classDef frontend fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#000
    classDef api fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#000
    classDef ws fill:#f3e5f5,stroke:#6a1b9a,stroke-width:2px,color:#000
    classDef db fill:#fce4ec,stroke:#c2185b,stroke-width:2px,color:#000

    class U1,U2 user
    class HA,HB frontend
    class API api
    class WS ws
    class DB db

    %% 流程
    U1 -->|"1️⃣ 点击聊一聊"| HA
    HA -->|"2️⃣ POST /conversations"| API
    API -->|"3️⃣ 查询/创建会话"| DB
    DB -->|"4️⃣ 返回数据"| API
    API -->|"5️⃣ 返回会话ID"| HA
    HA -->|"6️⃣ 跳转聊天页"| HA

    HA -->|"7️⃣ 连接WebSocket"| WS
    WS -->|"8️⃣ 验证Token"| WS
    WS -->|"9️⃣ auth:success"| HA
    HA -->|"🔟 subscribe"| WS
    WS -->|"1️⃣1️⃣ subscribe:success"| HA

    U2 -->|"1️⃣2️⃣ 打开消息页"| HB
    HB -->|"1️⃣3️⃣ GET /conversations"| API
    API -->|"1️⃣4️⃣ 返回详情"| HB
    HB -->|"1️⃣5️⃣ 连接WebSocket"| WS
    HB -->|"1️⃣6️⃣ subscribe"| WS

    U1 -->|"1️⃣7️⃣ 输入消息"| HA
    U1 -->|"1️⃣8️⃣ 点击发送"| HA
    HA -->|"1️⃣9️⃣ POST /messages"| API
    API -->|"2️⃣0️⃣ 验证权限"| API
    API -->|"2️⃣1️⃣ 保存消息"| DB
    DB -->|"2️⃣2️⃣ 返回消息ID"| API
    API -->|"2️⃣3️⃣ 更新last_message"| DB
    API -->|"2️⃣4️⃣ 返回消息"| HA
    HA -->|"2️⃣5️⃣ 显示消息"| HA

    API -->|"2️⃣6️⃣ 推送通知"| WS
    WS -->|"2️⃣7️⃣ message:new"| HB
    HB -->|"2️⃣8️⃣ 显示新消息"| HB
    HB -->|"2️⃣9️⃣ POST /read"| API
    API -->|"3️⃣0️⃣ 更新未读数"| DB
    API -->|"3️⃣1️⃣ 已读通知"| WS
    WS -->|"3️⃣2️⃣ conversation:read"| HA

    HA <-->|"💓 心跳保活"| WS
    HA -->|"🔄 断线重连"| WS
