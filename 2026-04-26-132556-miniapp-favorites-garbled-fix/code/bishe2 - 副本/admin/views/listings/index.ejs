<%
  const statusLabelMap = {
    pending_review: "待审核",
    approved: "已通过",
    rejected: "已拒绝",
    off_shelf: "已下架",
    removed: "已下架",
  };
%>

<div class="row g-3 mb-4">
  <div class="col-lg-8">
    <form class="row g-3" method="GET" action="/admin/listings">
      <div class="col-md-4">
        <label class="form-label">状态</label>
        <select name="status" class="form-select rounded-4">
          <% statusOptions.forEach((option) => { %>
            <option value="<%= option.value %>" <%= currentStatus === option.value ? "selected" : "" %>>
              <%= option.label %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">类型</label>
        <select name="type" class="form-select rounded-4">
          <% typeOptions.forEach((option) => { %>
            <option value="<%= option.value %>" <%= currentType === option.value ? "selected" : "" %>>
              <%= option.label %>
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <label class="form-label">关键词</label>
        <input
          name="keyword"
          value="<%= keyword %>"
          class="form-control rounded-4"
          placeholder="商品标题 / 卖家"
        />
      </div>
      <div class="col-12 d-flex gap-2">
        <button class="btn btn-dark rounded-4 px-4" type="submit">筛选</button>
        <a class="btn btn-outline-secondary rounded-4 px-4" href="/admin/listings">重置</a>
      </div>
    </form>
  </div>
  <div class="col-lg-4">
    <div class="row g-3">
      <div class="col-6">
        <div class="card stat-card h-100">
          <div class="card-body">
            <div class="text-muted small">当前结果</div>
            <div class="display-6 fw-bold"><%= total %></div>
          </div>
        </div>
      </div>
      <div class="col-6">
        <div class="card stat-card h-100">
          <div class="card-body">
            <div class="text-muted small">当前页</div>
            <div class="display-6 fw-bold"><%= currentPage %></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="table-responsive">
  <table class="table align-middle">
    <thead>
      <tr>
        <th>标题</th>
        <th>类型</th>
        <th>价格</th>
        <th>卖家</th>
        <th>区县</th>
        <th>状态</th>
        <th>发布时间</th>
        <th class="text-end">操作</th>
      </tr>
    </thead>
    <tbody>
      <% if (!listings.length) { %>
        <tr>
          <td colspan="8" class="py-5 text-center text-muted">当前筛选条件下没有数据。</td>
        </tr>
      <% } %>

      <% listings.forEach((listing) => { %>
        <tr>
          <td>
            <div class="fw-semibold"><%= listing.title %></div>
            <div class="small text-muted"><%= String(listing.description || "").slice(0, 42) %></div>
          </td>
          <td>
            <span class="type-pill <%= listing.listing_type %>">
              <%= listing.listing_type === "wanted" ? "求购帖" : "出售帖" %>
            </span>
          </td>
          <td>¥ <%= Number(listing.price || 0).toFixed(2) %></td>
          <td><%= listing.seller_nickname %></td>
          <td><%= listing.district_name %></td>
          <td>
            <span class="status-pill <%= listing.status %>"><%= statusLabelMap[listing.status] || listing.status %></span>
          </td>
          <td><%= new Date(listing.created_at).toLocaleString("zh-CN") %></td>
          <td class="text-end">
            <% if (listing.status === "off_shelf" || listing.status === "removed") { %>
              <form method="POST" action="/admin/listings/<%= listing.id || listing._id %>/restore" class="d-inline-block me-2">
                <button class="btn btn-sm btn-success rounded-4" type="submit">上架</button>
              </form>
            <% } else if (listing.status === "approved") { %>
              <form method="POST" action="/admin/listings/<%= listing.id || listing._id %>/remove" class="d-inline-block me-2">
                <button class="btn btn-sm btn-outline-danger rounded-4" type="submit">下架</button>
              </form>
            <% } %>
            <a class="btn btn-sm btn-outline-dark rounded-4" href="/admin/listings/<%= listing.id || listing._id %>">
              查看
            </a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<nav class="mt-4">
  <ul class="pagination">
    <% for (let pageNumber = 1; pageNumber <= totalPages; pageNumber += 1) { %>
      <li class="page-item <%= pageNumber === currentPage ? 'active' : '' %>">
        <a
          class="page-link"
          href="/admin/listings?status=<%= currentStatus %>&type=<%= currentType %>&keyword=<%= encodeURIComponent(keyword || '') %>&page=<%= pageNumber %>"
        >
          <%= pageNumber %>
        </a>
      </li>
    <% } %>
  </ul>
</nav>
