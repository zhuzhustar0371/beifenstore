<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>社区二手平台后台登录</title>
    <link
      href="https://cdn.bootcdn.net/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <style>
      body {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
          radial-gradient(circle at top right, rgba(255, 227, 81, 0.9), transparent 28%),
          linear-gradient(135deg, #f6f1df 0%, #fffaf0 100%);
      }

      .login-card {
        width: min(460px, calc(100vw - 32px));
        padding: 40px 36px;
        border-radius: 32px;
        background: rgba(255, 255, 255, 0.96);
        box-shadow: 0 20px 60px rgba(34, 34, 34, 0.12);
      }

      .hero-tag {
        display: inline-flex;
        align-items: center;
        padding: 8px 14px;
        border-radius: 999px;
        background: #ffe351;
        font-size: 13px;
        font-weight: 700;
      }
    </style>
  </head>
  <body>
    <div class="login-card">
      <div class="hero-tag mb-3">管理端 / 客服端统一登录</div>
      <h1 class="h3 fw-bold mb-2">社区二手平台后台</h1>
      <p class="text-muted mb-4">
        最高管理员使用后台账号登录。客服使用自己的 `openid` 加 `SERVICE_PASSWORD`
        登录，系统会按角色自动进入客服页面。
      </p>

      <% if (error && error.length) { %>
        <div class="alert alert-danger rounded-4 border-0"><%= error[0] %></div>
      <% } %>

      <% if (success && success.length) { %>
        <div class="alert alert-success rounded-4 border-0"><%= success[0] %></div>
      <% } %>

      <form method="POST" action="/login" class="d-grid gap-3" autocomplete="off">
        <input type="text" name="fake_account" autocomplete="username" tabindex="-1" hidden />
        <input type="password" name="fake_password" autocomplete="new-password" tabindex="-1" hidden />
        <div>
          <label for="account" class="form-label">账号</label>
          <input
            id="account"
            name="account"
            class="form-control form-control-lg rounded-4"
            placeholder="管理员用户名，或客服 openid"
            required
          />
        </div>

        <div>
          <label for="password" class="form-label">密码</label>
          <input
            id="password"
            name="password"
            type="password"
            class="form-control form-control-lg rounded-4"
            placeholder="请输入密码"
            required
          />
        </div>

        <button type="submit" class="btn btn-dark btn-lg rounded-4">登录后台</button>
      </form>

      <div class="small text-muted mt-4">
        默认管理员账号: `admin` / `admin123`
      </div>
      <div class="small text-muted">
        默认客服密码: `service123`
      </div>
      <div class="small mt-2">
        用户端 Web 入口: <a href="/app">/app</a>
      </div>
    </div>
  <script>
    (function () {
      const form = document.querySelector('form[action="/login"]');
      const accountInput = document.getElementById("account");
      const passwordInput = document.getElementById("password");

      if (form) {
        form.setAttribute("autocomplete", "off");
      }

      if (accountInput) {
        accountInput.setAttribute("autocomplete", "off");
        accountInput.setAttribute("autocapitalize", "off");
        accountInput.setAttribute("autocorrect", "off");
        accountInput.setAttribute("spellcheck", "false");
      }

      if (passwordInput) {
        passwordInput.setAttribute("autocomplete", "new-password");
        passwordInput.setAttribute("autocapitalize", "off");
        passwordInput.setAttribute("autocorrect", "off");
        passwordInput.setAttribute("spellcheck", "false");
      }
    })();
  </script>
  </body>
</html>
