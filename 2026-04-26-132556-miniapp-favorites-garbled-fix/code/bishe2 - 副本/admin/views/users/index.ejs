<style>
  .user-avatar-cell {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .user-avatar-thumb {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid rgba(37, 35, 33, 0.08);
    flex-shrink: 0;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .user-avatar-thumb:hover {
    transform: scale(1.08);
    box-shadow: 0 4px 12px rgba(37, 35, 33, 0.15);
  }

  .user-avatar-placeholder {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, #ffe351, #f5d909);
    display: grid;
    place-items: center;
    font-weight: 700;
    font-size: 14px;
    color: #252321;
    flex-shrink: 0;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .user-avatar-placeholder:hover {
    transform: scale(1.08);
    box-shadow: 0 4px 12px rgba(37, 35, 33, 0.15);
  }

  .avatar-upload-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 2000;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    justify-content: center;
    align-items: center;
  }

  .avatar-upload-overlay.active {
    display: flex;
  }

  .avatar-upload-card {
    background: #fff;
    border-radius: 24px;
    padding: 32px;
    width: min(480px, 92vw);
    max-height: 90vh;
    overflow-y: auto;
    box-shadow: 0 24px 48px rgba(0, 0, 0, 0.2);
  }

  .avatar-upload-card h3 {
    margin-bottom: 20px;
    font-weight: 700;
  }

  .avatar-preview-area {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 24px;
    margin: 20px 0;
    flex-wrap: wrap;
  }

  .avatar-preview-box {
    position: relative;
    width: 200px;
    height: 200px;
    border-radius: 20px;
    overflow: hidden;
    background: #f8f8f4;
    border: 2px dashed rgba(37, 35, 33, 0.15);
    display: grid;
    place-items: center;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .avatar-preview-box:hover {
    border-color: #f5d909;
  }

  .avatar-preview-box img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-preview-box .placeholder-text {
    color: rgba(37, 35, 33, 0.4);
    font-size: 14px;
    text-align: center;
  }

  .avatar-crop-container {
    position: relative;
    width: 200px;
    height: 200px;
    overflow: hidden;
    border-radius: 20px;
    background: #f8f8f4;
    border: 2px solid rgba(37, 35, 33, 0.08);
  }

  .avatar-crop-container canvas {
    position: absolute;
    top: 0;
    left: 0;
    cursor: grab;
  }

  .avatar-crop-container canvas:active {
    cursor: grabbing;
  }

  .avatar-crop-controls {
    display: flex;
    gap: 8px;
    justify-content: center;
    margin-top: 12px;
  }

  .avatar-crop-controls button {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(37, 35, 33, 0.12);
    background: #fff;
    font-size: 16px;
    cursor: pointer;
    display: grid;
    place-items: center;
    transition: background 0.15s;
  }

  .avatar-crop-controls button:hover {
    background: #f8f8f4;
  }

  .avatar-upload-progress {
    display: none;
    margin: 16px 0;
  }

  .avatar-upload-progress.active {
    display: block;
  }

  .avatar-progress-bar {
    height: 8px;
    border-radius: 4px;
    background: rgba(37, 35, 33, 0.08);
    overflow: hidden;
  }

  .avatar-progress-fill {
    height: 100%;
    border-radius: 4px;
    background: linear-gradient(90deg, #ffe351, #f5d909);
    transition: width 0.3s ease;
    width: 0%;
  }

  .avatar-progress-text {
    font-size: 12px;
    color: rgba(37, 35, 33, 0.56);
    margin-top: 6px;
    text-align: center;
  }

  .avatar-upload-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
    margin-top: 20px;
  }

  .avatar-size-hint {
    font-size: 12px;
    color: rgba(37, 35, 33, 0.56);
    margin-top: 8px;
    text-align: center;
  }
</style>

<form class="row g-3 mb-4" method="GET" action="/admin/users">
  <div class="col-md-3">
    <label class="form-label">状态</label>
    <select name="status" class="form-select rounded-4">
      <% statusOptions.forEach((option) => { %>
        <option value="<%= option.value %>" <%= currentStatus === option.value ? "selected" : "" %>>
          <%= option.label %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-3">
    <label class="form-label">角色</label>
    <select name="role" class="form-select rounded-4">
      <% roleOptions.forEach((option) => { %>
        <option value="<%= option.value %>" <%= currentRole === option.value ? "selected" : "" %>>
          <%= option.label %>
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-4">
    <label class="form-label">关键词</label>
    <input
      name="keyword"
      value="<%= keyword %>"
      class="form-control rounded-4"
      placeholder="昵称 / openid / 文档 ID"
    />
  </div>
  <div class="col-md-2 d-flex align-items-end">
    <button class="btn btn-dark rounded-4 w-100" type="submit">筛选</button>
  </div>
</form>

<div class="table-responsive">
  <table class="table align-middle">
    <thead>
      <tr>
        <th style="width: 180px;">用户</th>
        <th>OpenID</th>
        <th>角色</th>
        <th>状态</th>
        <th>发帖数</th>
        <th>创建时间</th>
        <th class="text-end">操作</th>
      </tr>
    </thead>
    <tbody>
      <% if (!users.length) { %>
        <tr>
          <td colspan="7" class="py-5 text-center text-muted">当前没有匹配用户。</td>
        </tr>
      <% } %>

      <% users.forEach((user) => { %>
        <tr id="user-row-<%= user._id || user.id %>">
          <td>
            <div class="user-avatar-cell">
              <% if (user.avatar_url) { %>
                <img
                  class="user-avatar-thumb"
                  src="<%= user.avatar_url %>"
                  alt="<%= user.nickname || '用户' %>"
                  onclick="openAvatarUpload('<%= user._id || user.id %>', '<%= user.avatar_url %>', '<%= (user.nickname || '').replace(/'/g, "\\'") %>')"
                />
              <% } else { %>
                <div
                  class="user-avatar-placeholder"
                  onclick="openAvatarUpload('<%= user._id || user.id %>', '', '<%= (user.nickname || '').replace(/'/g, "\\'") %>')"
                >
                  <%= String(user.nickname || "?").slice(0, 2) %>
                </div>
              <% } %>
              <div>
                <div class="fw-semibold"><%= user.nickname || "-" %></div>
                <div class="small text-muted"><%= user.id || user._id %></div>
                <% if ((user.role || "user") === "customer_service") { %>
                  <div class="small text-muted">客服登录：<%= user.username || user.account || user.openid || user.open_id || "-" %></div>
                <% } %>
              </div>
            </div>
          </td>
          <td><%= user.openid || user.open_id || "-" %></td>
          <td>
            <span class="type-pill <%= user.role === 'customer_service' ? 'wanted' : '' %>">
              <%= user.role || "user" %>
            </span>
          </td>
          <td>
            <span class="status-pill <%= user.status || 'active' %>"><%= user.status || "active" %></span>
          </td>
          <td><%= user.listing_count || 0 %></td>
          <td><%= new Date(user.created_at).toLocaleString("zh-CN") %></td>
          <td class="text-end">
            <div class="d-flex justify-content-end flex-wrap gap-2">
              <button
                class="btn btn-sm btn-outline-info rounded-4"
                onclick="openAvatarUpload('<%= user._id || user.id %>', '<%= user.avatar_url || "" %>', '<%= (user.nickname || "").replace(/'/g, "\\'") %>')"
              >头像</button>
              <% if ((user.role || "user") === "customer_service") { %>
                <form method="POST" action="/admin/users/<%= user._id || user.id %>/remove-service">
                  <button class="btn btn-sm btn-outline-warning rounded-4" type="submit">移除客服</button>
                </form>
              <% } else if ((user.role || "user") === "user") { %>
                <form method="POST" action="/admin/users/<%= user._id || user.id %>/make-service">
                  <button class="btn btn-sm btn-outline-dark rounded-4" type="submit">设为客服</button>
                </form>
              <% } %>

              <% if ((user.status || "active") === "disabled") { %>
                <form method="POST" action="/admin/users/<%= user._id || user.id %>/enable">
                  <button class="btn btn-sm btn-success rounded-4" type="submit">恢复</button>
                </form>
              <% } else { %>
                <form method="POST" action="/admin/users/<%= user._id || user.id %>/disable">
                  <button class="btn btn-sm btn-outline-danger rounded-4" type="submit">禁用</button>
                </form>
              <% } %>
              <form
                method="POST"
                action="/admin/users/<%= user._id || user.id %>/reset-password"
                data-user-name="<%= user.nickname || user.username || user.openid || user.open_id || '该用户' %>"
                onsubmit="return handleAdminPasswordReset(this)"
              >
                <input type="hidden" name="new_password" />
                <button class="btn btn-sm btn-outline-primary rounded-4" type="submit">重置密码</button>
              </form>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<nav class="mt-4">
  <ul class="pagination">
    <% for (let pageNumber = 1; pageNumber <= totalPages; pageNumber += 1) { %>
      <li class="page-item <%= pageNumber === currentPage ? 'active' : '' %>">
        <a
          class="page-link"
          href="/admin/users?status=<%= currentStatus %>&role=<%= currentRole %>&keyword=<%= encodeURIComponent(keyword || '') %>&page=<%= pageNumber %>"
        >
          <%= pageNumber %>
        </a>
      </li>
    <% } %>
  </ul>
</nav>

<div class="avatar-upload-overlay" id="avatarUploadOverlay">
  <div class="avatar-upload-card">
    <h3>上传头像 — <span id="avatarUserName"></span></h3>

    <div class="avatar-preview-area">
      <div>
        <div class="avatar-crop-container" id="avatarCropContainer">
          <canvas id="avatarCropCanvas" width="200" height="200"></canvas>
        </div>
        <div class="avatar-crop-controls">
          <button type="button" onclick="avatarCropZoom(0.1)" title="放大">+</button>
          <button type="button" onclick="avatarCropZoom(-0.1)" title="缩小">−</button>
          <button type="button" onclick="avatarCropReset()" title="重置">↺</button>
        </div>
        <div class="avatar-size-hint">拖拽移动，滚轮/按钮缩放 · 推荐 200×200px</div>
      </div>
      <div>
        <div style="font-size:12px;color:rgba(37,35,33,0.56);margin-bottom:8px;text-align:center;">预览效果</div>
        <div style="display:grid;gap:12px;place-items:center;">
          <canvas id="avatarPreviewLarge" width="80" height="80" style="width:80px;height:80px;border-radius:50%;border:2px solid rgba(37,35,33,0.08);"></canvas>
          <canvas id="avatarPreviewSmall" width="40" height="40" style="width:40px;height:40px;border-radius:50%;border:2px solid rgba(37,35,33,0.08);"></canvas>
        </div>
      </div>
    </div>

    <div class="avatar-upload-progress" id="avatarUploadProgress">
      <div class="avatar-progress-bar">
        <div class="avatar-progress-fill" id="avatarProgressFill"></div>
      </div>
      <div class="avatar-progress-text" id="avatarProgressText">上传中 0%</div>
    </div>

    <div class="avatar-upload-actions">
      <button class="btn btn-outline-dark rounded-4" type="button" onclick="closeAvatarUpload()">取消</button>
      <label class="btn btn-dark rounded-4" style="margin:0;cursor:pointer;">
        选择图片
        <input type="file" id="avatarFileInput" accept="image/jpeg,image/jpg,image/png,image/webp" style="display:none;" onchange="handleAvatarFileSelect(event)" />
      </label>
      <button class="btn btn-dark rounded-4" type="button" id="avatarUploadBtn" onclick="uploadAvatar()" disabled>上传头像</button>
    </div>
  </div>
</div>

<script>
(function () {
  let avatarState = {
    userId: null,
    currentAvatarUrl: "",
    originalImage: null,
    cropX: 0,
    cropY: 0,
    cropScale: 1,
    isDragging: false,
    dragStartX: 0,
    dragStartY: 0,
    dragStartCropX: 0,
    dragStartCropY: 0,
  };

  const cropCanvas = document.getElementById("avatarCropCanvas");
  const cropCtx = cropCanvas ? cropCanvas.getContext("2d") : null;
  const previewLarge = document.getElementById("avatarPreviewLarge");
  const previewLargeCtx = previewLarge ? previewLarge.getContext("2d") : null;
  const previewSmall = document.getElementById("avatarPreviewSmall");
  const previewSmallCtx = previewSmall ? previewSmall.getContext("2d") : null;

  window.openAvatarUpload = function (userId, currentUrl, userName) {
    avatarState.userId = userId;
    avatarState.currentAvatarUrl = currentUrl;
    avatarState.originalImage = null;
    avatarState.cropX = 0;
    avatarState.cropY = 0;
    avatarState.cropScale = 1;

    document.getElementById("avatarUserName").textContent = userName || "用户";
    document.getElementById("avatarUploadBtn").disabled = true;
    document.getElementById("avatarFileInput").value = "";
    document.getElementById("avatarUploadProgress").classList.remove("active");

    if (cropCtx) {
      cropCtx.clearRect(0, 0, 200, 200);
      cropCtx.fillStyle = "#f8f8f4";
      cropCtx.fillRect(0, 0, 200, 200);
      cropCtx.fillStyle = "rgba(37,35,33,0.3)";
      cropCtx.font = "14px sans-serif";
      cropCtx.textAlign = "center";
      cropCtx.fillText("点击「选择图片」上传头像", 100, 105);
    }

    if (previewLargeCtx) {
      previewLargeCtx.clearRect(0, 0, 80, 80);
      previewLargeCtx.fillStyle = "#f8f8f4";
      previewLargeCtx.fillRect(0, 0, 80, 80);
    }

    if (previewSmallCtx) {
      previewSmallCtx.clearRect(0, 0, 40, 40);
      previewSmallCtx.fillStyle = "#f8f8f4";
      previewSmallCtx.fillRect(0, 0, 40, 40);
    }

    if (currentUrl) {
      const img = new Image();
      img.crossOrigin = "anonymous";
      img.onload = function () {
        avatarState.originalImage = img;
        avatarState.cropScale = Math.max(200 / img.width, 200 / img.height);
        avatarState.cropX = (img.width * avatarState.cropScale - 200) / 2 / avatarState.cropScale;
        avatarState.cropY = (img.height * avatarState.cropScale - 200) / 2 / avatarState.cropScale;
        renderCropPreview();
        document.getElementById("avatarUploadBtn").disabled = false;
      };
      img.src = currentUrl;
    }

    document.getElementById("avatarUploadOverlay").classList.add("active");
  };

  window.closeAvatarUpload = function () {
    document.getElementById("avatarUploadOverlay").classList.remove("active");
  };

  window.handleAvatarFileSelect = function (event) {
    const file = event.target.files[0];
    if (!file) return;

    if (file.size > 5 * 1024 * 1024) {
      alert("图片文件大小不能超过 5MB，请选择更小的图片。");
      event.target.value = "";
      return;
    }

    const allowedTypes = ["image/jpeg", "image/jpg", "image/pjpeg", "image/png", "image/webp"];
    if (!allowedTypes.includes(file.type)) {
      alert("仅支持 JPG、PNG、WEBP 格式的图片。");
      event.target.value = "";
      return;
    }

    const reader = new FileReader();
    reader.onload = function (e) {
      const img = new Image();
      img.onload = function () {
        avatarState.originalImage = img;
        avatarState.cropScale = Math.max(200 / img.width, 200 / img.height);
        avatarState.cropX = (img.width * avatarState.cropScale - 200) / 2 / avatarState.cropScale;
        avatarState.cropY = (img.height * avatarState.cropScale - 200) / 2 / avatarState.cropScale;
        renderCropPreview();
        document.getElementById("avatarUploadBtn").disabled = false;
      };
      img.src = e.target.result;
    };
    reader.readAsDataURL(file);
  };

  function renderCropPreview() {
    if (!avatarState.originalImage || !cropCtx) return;

    const img = avatarState.originalImage;
    const scale = avatarState.cropScale;
    const sx = avatarState.cropX;
    const sy = avatarState.cropY;

    cropCtx.clearRect(0, 0, 200, 200);
    cropCtx.fillStyle = "#f8f8f4";
    cropCtx.fillRect(0, 0, 200, 200);
    cropCtx.drawImage(img, sx * scale, sy * scale, 200, 200, 0, 0, 200, 200);

    if (previewLargeCtx) {
      previewLargeCtx.clearRect(0, 0, 80, 80);
      previewLargeCtx.save();
      previewLargeCtx.beginPath();
      previewLargeCtx.arc(40, 40, 40, 0, Math.PI * 2);
      previewLargeCtx.clip();
      previewLargeCtx.drawImage(img, sx * scale, sy * scale, 200, 200, 0, 0, 80, 80);
      previewLargeCtx.restore();
    }

    if (previewSmallCtx) {
      previewSmallCtx.clearRect(0, 0, 40, 40);
      previewSmallCtx.save();
      previewSmallCtx.beginPath();
      previewSmallCtx.arc(20, 20, 20, 0, Math.PI * 2);
      previewSmallCtx.clip();
      previewSmallCtx.drawImage(img, sx * scale, sy * scale, 200, 200, 0, 0, 40, 40);
      previewSmallCtx.restore();
    }
  }

  window.avatarCropZoom = function (delta) {
    if (!avatarState.originalImage) return;
    const img = avatarState.originalImage;
    const oldScale = avatarState.cropScale;
    avatarState.cropScale = Math.max(
      Math.max(200 / img.width, 200 / img.height),
      Math.min(oldScale + delta, Math.max(200 / img.width * 4, 200 / img.height * 4))
    );

    const centerX = avatarState.cropX + 100 / oldScale;
    const centerY = avatarState.cropY + 100 / oldScale;
    avatarState.cropX = centerX - 100 / avatarState.cropScale;
    avatarState.cropY = centerY - 100 / avatarState.cropScale;

    clampCropPosition();
    renderCropPreview();
  };

  window.avatarCropReset = function () {
    if (!avatarState.originalImage) return;
    const img = avatarState.originalImage;
    avatarState.cropScale = Math.max(200 / img.width, 200 / img.height);
    avatarState.cropX = (img.width * avatarState.cropScale - 200) / 2 / avatarState.cropScale;
    avatarState.cropY = (img.height * avatarState.cropScale - 200) / 2 / avatarState.cropScale;
    renderCropPreview();
  };

  function clampCropPosition() {
    if (!avatarState.originalImage) return;
    const img = avatarState.originalImage;
    const scale = avatarState.cropScale;
    const maxCropX = img.width - 200 / scale;
    const maxCropY = img.height - 200 / scale;
    avatarState.cropX = Math.max(0, Math.min(avatarState.cropX, maxCropX));
    avatarState.cropY = Math.max(0, Math.min(avatarState.cropY, maxCropY));
  }

  if (cropCanvas) {
    cropCanvas.addEventListener("mousedown", function (e) {
      if (!avatarState.originalImage) return;
      avatarState.isDragging = true;
      avatarState.dragStartX = e.clientX;
      avatarState.dragStartY = e.clientY;
      avatarState.dragStartCropX = avatarState.cropX;
      avatarState.dragStartCropY = avatarState.cropY;
    });

    document.addEventListener("mousemove", function (e) {
      if (!avatarState.isDragging) return;
      const scale = avatarState.cropScale;
      const dx = (avatarState.dragStartX - e.clientX) / scale;
      const dy = (avatarState.dragStartY - e.clientY) / scale;
      avatarState.cropX = avatarState.dragStartCropX + dx;
      avatarState.cropY = avatarState.dragStartCropY + dy;
      clampCropPosition();
      renderCropPreview();
    });

    document.addEventListener("mouseup", function () {
      avatarState.isDragging = false;
    });

    cropCanvas.addEventListener("wheel", function (e) {
      e.preventDefault();
      const delta = e.deltaY > 0 ? -0.05 : 0.05;
      avatarCropZoom(delta);
    }, { passive: false });

    cropCanvas.addEventListener("touchstart", function (e) {
      if (!avatarState.originalImage || e.touches.length !== 1) return;
      avatarState.isDragging = true;
      avatarState.dragStartX = e.touches[0].clientX;
      avatarState.dragStartY = e.touches[0].clientY;
      avatarState.dragStartCropX = avatarState.cropX;
      avatarState.dragStartCropY = avatarState.cropY;
    }, { passive: true });

    cropCanvas.addEventListener("touchmove", function (e) {
      if (!avatarState.isDragging || e.touches.length !== 1) return;
      e.preventDefault();
      const scale = avatarState.cropScale;
      const dx = (avatarState.dragStartX - e.touches[0].clientX) / scale;
      const dy = (avatarState.dragStartY - e.touches[0].clientY) / scale;
      avatarState.cropX = avatarState.dragStartCropX + dx;
      avatarState.cropY = avatarState.dragStartCropY + dy;
      clampCropPosition();
      renderCropPreview();
    }, { passive: false });

    cropCanvas.addEventListener("touchend", function () {
      avatarState.isDragging = false;
    });
  }

  window.uploadAvatar = function () {
    if (!avatarState.userId || !avatarState.originalImage) return;

    const exportCanvas = document.createElement("canvas");
    exportCanvas.width = 200;
    exportCanvas.height = 200;
    const exportCtx = exportCanvas.getContext("2d");

    const img = avatarState.originalImage;
    const scale = avatarState.cropScale;
    exportCtx.drawImage(img, avatarState.cropX * scale, avatarState.cropY * scale, 200, 200, 0, 0, 200, 200);

    exportCanvas.toBlob(function (blob) {
      if (!blob) {
        alert("图片处理失败，请重试。");
        return;
      }

      const formData = new FormData();
      formData.append("avatar", blob, "avatar.jpg");

      const xhr = new XMLHttpRequest();
      const progressEl = document.getElementById("avatarUploadProgress");
      const progressFill = document.getElementById("avatarProgressFill");
      const progressText = document.getElementById("avatarProgressText");
      const uploadBtn = document.getElementById("avatarUploadBtn");

      progressEl.classList.add("active");
      uploadBtn.disabled = true;

      xhr.upload.addEventListener("progress", function (e) {
        if (e.lengthComputable) {
          const pct = Math.round((e.loaded / e.total) * 100);
          progressFill.style.width = pct + "%";
          progressText.textContent = "上传中 " + pct + "%";
        }
      });

      xhr.addEventListener("load", function () {
        progressFill.style.width = "100%";
        progressText.textContent = "上传完成";

        try {
          const result = JSON.parse(xhr.responseText);
          if (result.success) {
            const row = document.getElementById("user-row-" + avatarState.userId);
            if (row) {
              const thumb = row.querySelector(".user-avatar-thumb");
              const placeholder = row.querySelector(".user-avatar-placeholder");
              if (thumb) {
                thumb.src = result.avatar_url + "?t=" + Date.now();
              } else if (placeholder) {
                const newImg = document.createElement("img");
                newImg.className = "user-avatar-thumb";
                newImg.src = result.avatar_url + "?t=" + Date.now();
                newImg.alt = document.getElementById("avatarUserName").textContent;
                newImg.onclick = placeholder.onclick;
                placeholder.parentNode.replaceChild(newImg, placeholder);
              }
            }
            setTimeout(function () {
              closeAvatarUpload();
            }, 800);
          } else {
            alert(result.message || "上传失败");
            uploadBtn.disabled = false;
          }
        } catch (parseErr) {
          alert("上传响应解析失败");
          uploadBtn.disabled = false;
        }
      });

      xhr.addEventListener("error", function () {
        progressText.textContent = "上传失败";
        uploadBtn.disabled = false;
      });

      xhr.open("POST", "/admin/users/" + avatarState.userId + "/avatar");
      xhr.send(formData);
    }, "image/jpeg", 0.92);
  };

  document.getElementById("avatarUploadOverlay").addEventListener("click", function (e) {
    if (e.target === this) {
      closeAvatarUpload();
    }
  });
})();
</script>
