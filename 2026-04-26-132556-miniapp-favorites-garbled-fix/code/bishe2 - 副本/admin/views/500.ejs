<!DOCTYPE html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>系统错误</title>
    <link
      href="https://cdn.bootcdn.net/ajax/libs/bootstrap/5.3.3/css/bootstrap.min.css"
      rel="stylesheet"
    />
  </head>
  <body class="bg-light d-flex align-items-center" style="min-height: 100vh;">
    <div class="container text-center">
      <h1 class="display-4 fw-bold">500</h1>
      <p class="lead text-muted">后台执行失败，请查看服务端日志。</p>
      <% if (error) { %>
        <div class="alert alert-warning rounded-4 border-0 d-inline-block text-start"><%= error %></div>
      <% } %>
      <div>
        <a href="/login" class="btn btn-dark rounded-4 px-4">返回登录</a>
      </div>
    </div>
  </body>
</html>
