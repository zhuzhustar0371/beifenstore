.container {
  min-height: 100vh;
  background-color: var(--bg-page);
  position: relative;
  overflow: hidden;
}

.pb-40 {
  padding-bottom: 220rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 480rpx;
  background: var(--primary-gradient);
  border-radius: 0 0 60rpx 60rpx;
  z-index: 0;
}

.user-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 60rpx 40rpx 40rpx;
}

.avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: 64rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 6rpx;
  backdrop-filter: blur(4rpx);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--white);
}

.info-wrap {
  flex: 1;
  margin-left: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.user-subline {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.login-tip {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.arrow-icon {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.6);
}

.assets-box {
  position: relative;
  z-index: 1;
  background: var(--white);
  border-radius: 24rpx;
  margin: 20rpx 32rpx 32rpx;
  padding: 32rpx 0;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.asset-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.divider-left {
  position: relative;
}

.divider-left::before {
  content: '';
  position: absolute;
  left: 0;
  top: 15%;
  height: 70%;
  width: 1rpx;
  background: var(--border);
}

.asset-val {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.asset-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.card-box {
  position: relative;
  z-index: 1;
  background: var(--white);
  border-radius: 24rpx;
  margin: 0 32rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 32rpx 0;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.grid-icon {
  width: 64rpx;
  height: 64rpx;
  margin-bottom: 16rpx;
  display: block;
  overflow: hidden;
  flex-shrink: 0;
}

.grid-icon-image {
  background: transparent;
}

.rule-icon {
  border-radius: 32rpx;
  background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
}

.grid-item text {
  font-size: 24rpx;
  color: var(--text-main);
}

.menu-list {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  background: var(--white);
  border-bottom: 1px solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.contact-btn {
  border: none;
  background: transparent;
  border-radius: 0;
  line-height: inherit;
  font-size: inherit;
  margin: 0;
  text-align: left;
}

.contact-btn::after {
  display: none;
}

.menu-label {
  font-size: 30rpx;
  color: var(--text-main);
}

.arrow {
  color: var(--text-placeholder);
  font-size: 32rpx;
}

.logout-box {
  margin: 48rpx 40rpx;
}

.logout-btn {
  background: var(--white);
  color: var(--text-main);
  font-size: 30rpx;
  border-radius: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.03);
}
