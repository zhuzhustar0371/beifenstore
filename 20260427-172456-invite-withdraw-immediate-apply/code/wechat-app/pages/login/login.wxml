<view class="login-container">
  <view class="bg-shape-1"></view>
  <view class="bg-shape-2"></view>

  <view class="content">
    <view class="header">
      <view class="logo-box">
        <text class="logo-text">知</text>
      </view>
      <text class="title">知禧净享生活</text>
      <text class="subtitle">品质生活 · 精致护肤 · 尊享健康</text>
    </view>

    <view class="auth-box">
      <block wx:if="{{loginStep == 1}}">
        <button class="btn-primary auth-btn" bindtap="onGetUserInfo">
          <text class="btn-text">微信授权一键登录</text>
        </button>
        <view class="no-login" bindtap="onCancel">暂不登录</view>
      </block>

      <block wx:elif="{{loginStep == 2}}">
        <button class="btn-outline auth-btn" open-type="chooseAvatar" bindchooseavatar="chooseAvatar">
          <text>上传微信头像</text>
        </button>
      </block>

      <block wx:elif="{{loginStep == 3}}">
        <input
          id="nickname-input"
          class="nickname-input"
          type="nickname"
          placeholder="请输入用户昵称"
          value="{{nickname}}"
          bindinput="onNicknameInput"
        />
        <button class="btn-primary auth-btn" bindtap="onEnterProgram">进入程序</button>
      </block>

      <view class="agreement-wrapper flex-row justify-center">
        <radio color="#059669" checked="{{agreed}}" bindtap="toggleAgreement" class="agree-radio" />
        <view class="agreement-text">
          <text>我已阅读并同意</text>
          <text class="agreement-link" bindtap="openAgreement">《用户协议》</text>
          <text>和</text>
          <text class="agreement-link" bindtap="openPrivacy">《隐私政策》</text>
        </view>
      </view>
    </view>
  </view>
</view>
