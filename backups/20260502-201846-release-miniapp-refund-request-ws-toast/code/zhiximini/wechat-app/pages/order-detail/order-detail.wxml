<view class="container pb-60">
  <view wx:if="{{loading}}" class="loading-state">加载中...</view>

  <block wx:if="{{order}}">
    <view class="status-header status-bg-{{order.statusClass}}">
      <view class="status-content">
        <text class="status-title">{{order.statusText}}</text>
        <text class="status-sub">订单号 {{order.id}}</text>
      </view>
    </view>

    <view class="address-card">
      <view class="location-icon"></view>
      <view class="address-info">
        <view class="name-phone">
          <text class="address-name">{{order.address.name}}</text>
          <text class="address-phone">{{order.address.phone}}</text>
        </view>
        <text class="address-detail">{{order.address.detail}}</text>
      </view>
    </view>

    <view class="goods-card">
      <view class="section-title">商品明细</view>
      <view class="goods-item">
        <image class="thumb" src="{{order.productImageUrl}}" mode="aspectFill" />
        <view class="info">
          <text class="name text-ellipsis">{{order.productName}}</text>
          <text class="spec">数量: {{order.quantity}}</text>
          <view class="price-wrap">
            <text class="price">¥{{order.unitPrice}}</text>
            <text class="count">x{{order.quantity}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="summary-card">
      <view class="summary-row">
        <text class="label">商品总额</text>
        <text class="value">¥{{order.productAmount}}</text>
      </view>
      <view class="summary-row">
        <text class="label">运费</text>
        <text class="value">¥{{order.shippingFee}}</text>
      </view>
      <view class="summary-row">
        <text class="label">返现基数</text>
        <text class="value">¥{{order.cashbackBaseAmount}}</text>
      </view>
      <view class="divider"></view>
      <view class="summary-row total-row">
        <text class="label color-main">实付款</text>
        <text class="highlight">¥{{order.totalAmount}}</text>
      </view>
    </view>

    <view class="info-card">
      <view class="info-row">
        <text class="label">创建时间</text>
        <text class="value">{{order.createdAt}}</text>
      </view>
      <view class="info-row" wx:if="{{order.paymentTransactionId}}">
        <text class="label">支付单号</text>
        <text class="value">{{order.paymentTransactionId}}</text>
      </view>
      <view class="info-row" wx:if="{{order.trackingNo}}">
        <text class="label">物流单号</text>
        <text class="value">{{order.trackingNo}}</text>
      </view>
    </view>

    <view class="bottom-action-bar" wx:if="{{order.status === 'PENDING'}}">
      <button class="btn-primary flex-1" bindtap="pay">立即付款</button>
    </view>

    <view class="bottom-action-bar" wx:if="{{order.canConfirmReceive}}">
      <button class="btn-primary flex-1" bindtap="confirmReceipt" loading="{{syncingTradeStatus}}">确认收货</button>
    </view>

    <view class="refund-status-bar" wx:if="{{order.refundRequestStatus === 'PENDING'}}">
      <text class="refund-status-pending">退款申请待审核</text>
    </view>
    <view class="refund-status-bar refund-status-rejected" wx:elif="{{order.refundRequestStatus === 'REJECTED'}}">
      <text class="refund-status-text">退款申请已驳回</text>
      <text class="refund-status-remark" wx:if="{{order.refundReviewRemark}}">备注: {{order.refundReviewRemark}}</text>
    </view>

    <view class="bottom-action-bar" wx:if="{{order.canRefundRequest}}">
      <button class="btn-primary flex-1" bindtap="openRefundPopup">申请退款</button>
    </view>
  </block>

  <!-- Refund request popup -->
  <view class="refund-popup-mask" wx:if="{{showRefundPopup}}" bindtap="closeRefundPopup"></view>
  <view class="refund-popup" wx:if="{{showRefundPopup}}">
    <view class="refund-popup__header">
      <text class="refund-popup__title">申请退款</text>
      <text class="refund-popup__close" bindtap="closeRefundPopup">×</text>
    </view>
    <view class="refund-popup__body">
      <textarea
        class="refund-popup__textarea"
        placeholder="请输入退款理由（选填）"
        maxlength="200"
        value="{{refundReason}}"
        bindinput="onRefundReasonInput"
        auto-height
      />
      <text class="refund-popup__count">{{refundReason.length || 0}}/200</text>
    </view>
    <view class="refund-popup__actions">
      <button class="refund-popup__btn refund-popup__btn--cancel" bindtap="closeRefundPopup">取消</button>
      <button class="refund-popup__btn refund-popup__btn--submit" bindtap="submitRefundRequest" loading="{{submittingRefund}}">提交申请</button>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!order && !loading}}">
    <view class="empty-icon"></view>
    <text class="empty-text">订单不存在或已失效</text>
  </view>
</view>
