<!-- 收货地址列表 -->
<view class="page">
  <view class="list" wx:if="{{list.length > 0}}">
    <view
      class="address-card card"
      wx:for="{{list}}"
      wx:key="id"
    >
      <view class="main">
        <text class="name">{{item.name}}</text>
        <text class="phone">{{item.phone}}</text>
        <text class="default-tag" wx:if="{{item.isDefault}}">默认</text>
      </view>
      <text class="addr">{{item.region}} {{item.detail}}</text>
      <view class="actions">
        <text bindtap="edit" data-id="{{item.id}}">编辑</text>
        <text bindtap="del" data-id="{{item.id}}">删除</text>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <text>暂无收货地址</text>
  </view>

  <view class="footer">
    <button class="btn-add btn-primary" bindtap="add">新增收货地址</button>
  </view>
</view>
