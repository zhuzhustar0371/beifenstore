<view class="container pb-60">
  <view class="tab-wrapper">
    <scroll-view class="tabs" scroll-x="true" scroll-with-animation="true">
      <view class="tab-scroll-inner">
        <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" data-tab="all" bindtap="switchTab">
          <text>全部</text>
          <view class="tab-line" wx:if="{{currentTab === 'all'}}"></view>
        </view>
        <view class="tab-item {{currentTab === 'unpaid' ? 'active' : ''}}" data-tab="unpaid" bindtap="switchTab">
          <text>待付款</text>
          <view class="tab-line" wx:if="{{currentTab === 'unpaid'}}"></view>
        </view>
        <view class="tab-item {{currentTab === 'unship' ? 'active' : ''}}" data-tab="unship" bindtap="switchTab">
          <text>待发货</text>
          <view class="tab-line" wx:if="{{currentTab === 'unship'}}"></view>
        </view>
        <view class="tab-item {{currentTab === 'unreceive' ? 'active' : ''}}" data-tab="unreceive" bindtap="switchTab">
          <text>待收货</text>
          <view class="tab-line" wx:if="{{currentTab === 'unreceive'}}"></view>
        </view>
        <view class="tab-item {{currentTab === 'done' ? 'active' : ''}}" data-tab="done" bindtap="switchTab">
          <text>已完成</text>
          <view class="tab-line" wx:if="{{currentTab === 'done'}}"></view>
        </view>
      </view>
    </scroll-view>
  </view>

  <view wx:if="{{loading}}" class="loading-state">加载中...</view>

  <view class="list" wx:elif="{{list.length > 0}}">
    <view class="order-card" wx:for="{{list}}" wx:key="id" bindtap="goDetail" data-id="{{item.id}}">
      <view class="order-header">
        <text class="order-no">订单号 {{item.id}}</text>
        <text class="status status-{{item.statusClass}}">{{item.statusText}}</text>
      </view>

      <view class="order-body">
        <view class="thumb-wrap">
          <image class="thumb" src="{{item.productImageUrl}}" mode="aspectFill" />
        </view>
        <view class="info">
          <text class="name text-ellipsis">{{item.productName}}</text>
          <text class="spec">数量: {{item.quantity}}</text>
          <view class="amount-wrap">
            <text class="amount-symbol">¥</text>
            <text class="amount-val">{{item.totalAmount}}</text>
          </view>
        </view>
      </view>

      <view class="order-footer">
        <text class="time">{{item.createdAt || '刚刚'}}</text>
        <view class="actions">
          <button class="btn-action primary" wx:if="{{item.status === 'PENDING'}}" catchtap="pay" data-id="{{item.id}}">立即付款</button>
          <button class="btn-action default" wx:if="{{item.canConfirmReceive}}" catchtap="confirm" data-id="{{item.id}}" loading="{{syncingTradeOrderId === item.id}}">确认收货</button>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:else>
    <view class="empty-icon"></view>
    <text class="empty-text">暂无相关订单记录</text>
  </view>
</view>
