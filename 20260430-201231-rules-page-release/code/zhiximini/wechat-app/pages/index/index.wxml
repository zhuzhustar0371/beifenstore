<view class="container">
  <view class="hero-banner">
    <view class="hero-content">
      <view class="hero-tag">官方严选</view>
      <text class="hero-title">知禧好物 · 净享生活</text>
      <text class="hero-sub">品质护肤洗护 / 自购享返现 / 邀请有礼</text>
    </view>
  </view>

  <view class="content-stack">
    <view class="section-header">
      <text class="section-title">优选推荐</text>
      <button class="section-action-btn" bindtap="scrollToBenefits">权益</button>
    </view>

    <view wx:if="{{loading}}" class="loading-card">
      <text>加载中...</text>
    </view>

    <block wx:elif="{{visibleProducts && visibleProducts.length > 0}}">
      <view class="product-list {{hasProductGrid ? 'product-list-grid' : ''}}">
        <view class="product-card" wx:for="{{visibleProducts}}" wx:key="id" bindtap="goProduct" data-id="{{item.id}}">
          <view class="product-image-box">
            <image class="product-image" src="{{item.imageUrl || '/images/product-placeholder.png'}}" mode="aspectFill"></image>
            <view class="tag-row">
              <text class="tag-hot" wx:if="{{item.featured || index === 0}}">热卖</text>
              <text class="tag-soft" wx:if="{{item.featured || index === 0}}">优选</text>
            </view>
          </view>
          <view class="product-content">
            <text class="product-name text-ellipsis">{{item.name}}</text>
            <text class="product-desc text-ellipsis">{{item.description || '单价 10 元 / 件，温和洁净，适合家庭日常使用'}}</text>
            <view class="product-bottom">
              <view class="price-box">
                <text class="price-symbol">¥</text>
                <text class="price-value">{{item.priceText || item.price}}</text>
              </view>
              <view class="buy-btn-icon">+</view>
            </view>
          </view>
        </view>
      </view>
    </block>

    <view wx:else class="empty-card">
      <text>暂无商品上架</text>
    </view>

    <view id="benefits-section" class="benefits-section-anchor">
      <view class="section-header">
        <view class="benefits-header-main">
          <view class="benefits-accent"></view>
          <text class="benefits-title">知禧会员权益</text>
        </view>
        <button class="section-action-btn section-action-btn--small" bindtap="scrollToRules">规则</button>
      </view>
    </view>

    <view class="benefits-card">

      <view class="summary-card">
        <text class="summary-price">{{featuredPriceText}} 元 · 当前活动单价 · 自购享返现</text>
        <text class="summary-desc">强力去污 · 无荧光添加 · 全家适用</text>
      </view>

      <view class="benefits-section">
        <text class="benefits-section-title">成为 VIP 会员，三步实现免单</text>
        <view class="steps-list">
          <view class="step-item">
            <view class="step-index">1</view>
            <text class="step-text">购买产品，立即获得推广资格</text>
          </view>
          <view class="step-item">
            <view class="step-index">2</view>
            <text class="step-text">成功推荐 3 位好友完成首单</text>
          </view>
          <view class="step-item">
            <view class="step-index">3</view>
            <text class="step-text">全额返现 {{featuredPriceText}} 元，实现本单免单</text>
          </view>
        </view>
      </view>

      <view class="section-divider"></view>

      <view class="benefits-section share-section">
        <text class="benefits-section-title">分享不止免单</text>
        <text class="benefits-section-subtitle">好物自己用，推荐还能拿奖励</text>
        <view class="share-list">
          <view class="share-item">
            <view class="share-dot"></view>
            <text class="share-text">好友首单成功，你即可获得对应奖励</text>
          </view>
          <view class="share-item">
            <view class="share-dot"></view>
            <text class="share-text">规则简单透明，仅统计一级推荐</text>
          </view>
          <view class="share-item">
            <view class="share-dot"></view>
            <text class="share-text">商品再多也能一键跳到底部查看规则</text>
          </view>
        </view>
      </view>

      <view class="footer-slogan">
        <text class="footer-title">好产品 + 好权益 = 更顺手的购买与分享体验</text>
        <text class="footer-subtitle">知禧净享生活，从首页就能快速找到重点内容</text>
      </view>
    </view>

    <view id="rules-section" class="rules-card">
      <view class="rules-header">
        <text class="rules-title">活动规则</text>
      </view>
      <view class="rules-list">
        <view class="rule-item" wx:for="{{ruleItems}}" wx:key="index">
          <text class="rule-index">{{index + 1}}</text>
          <text class="rule-text">{{item}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
