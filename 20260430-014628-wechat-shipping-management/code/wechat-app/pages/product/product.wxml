<view class="container pb-140">
  <view wx:if="{{loading}}" class="loading-state">加载中...</view>
  
  <block wx:if="{{product}}">
    <!-- Image Header -->
    <view class="hero-image-wrap">
      <image class="hero-image" src="{{product.imageUrl || '/images/product-placeholder.png'}}" mode="aspectFill" />
      <view class="image-overlay"></view>
    </view>

    <!-- Content Area -->
    <view class="content-sheet">
      <view class="title-row">
        <text class="price-symbol color-red">¥</text>
        <text class="price-huge color-red">{{product.price}}</text>
        <view class="stock-badge">库存充足</view>
      </view>
      
      <text class="product-title">{{product.name}}</text>
      <text class="product-sub">{{product.description || '官方精选 · 品质生活 · 尊享健康保障'}}</text>
      
      <view class="divider"></view>

      <view class="spec-row">
        <text class="spec-label">购买数量</text>
        <view class="stepper">
          <view class="step-btn {{count <= 1 ? 'disabled' : ''}}" bindtap="minus">-</view>
          <input class="step-input" type="number" value="{{count}}" bindinput="onCountInput" />
          <view class="step-btn" bindtap="plus">+</view>
        </view>
      </view>
      
      <!-- Placeholder Details -->
      <view class="details-section">
        <text class="section-title">图文详情</text>
        <view class="dummy-text">
          成分温和，源自天然植物萃取。专业科研配方，深入肌底修护，绽放莹润光泽。\n\n
          【适用对象】所有人群 \n
          【贮藏方法】避光、防潮、置于阴凉干燥处
        </view>
      </view>
    </view>
  </block>

  <!-- Bottom Action Bar -->
  <view class="bottom-bar" wx:if="{{product}}">
    <view class="total-wrap">
      <text class="fs-24 color-secondary">合计：</text>
      <text class="fs-28 color-red fw-600">¥</text>
      <text class="fs-40 color-red fw-700 ml-xs">{{total}}</text>
    </view>
    <button class="btn-primary buy-now-btn" bindtap="submitOrder">立即结算</button>
  </view>
</view>
