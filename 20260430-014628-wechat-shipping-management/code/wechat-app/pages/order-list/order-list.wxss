.container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

.pb-60 { padding-bottom: 60rpx; }

.tab-wrapper {
  background: var(--white);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}

.tabs {
  width: 100%;
  white-space: nowrap;
}

.tab-scroll-inner {
  display: flex;
  padding: 0 16rpx;
}

.tab-item {
  position: relative;
  flex: 1;
  min-width: 140rpx;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.3s;
}

.tab-item.active {
  color: var(--primary);
  font-weight: 600;
  font-size: 30rpx;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: var(--primary-gradient);
  border-radius: 4rpx;
}

.loading-state {
  text-align: center;
  padding: 80rpx;
  color: var(--text-placeholder);
}

.list {
  padding: 24rpx;
}

.order-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.03);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.order-no {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.status {
  font-size: 26rpx;
  font-weight: 500;
}

.status-pending { color: #ff5000; }
.status-paid { color: #07c160; }
.status-shipped { color: #1890ff; }
.status-completed { color: var(--text-secondary); }

.order-body {
  display: flex;
  background: var(--bg-page);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 24rpx;
}

.thumb-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background: #fff;
  flex-shrink: 0;
}

.thumb {
  width: 100%;
  height: 100%;
}

.info {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 12rpx;
}

.spec {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.amount-wrap {
  margin-top: auto;
  align-self: flex-end;
  display: flex;
  align-items: baseline;
}

.amount-symbol {
  font-size: 24rpx;
  color: var(--text-main);
  font-weight: 600;
}

.amount-val {
  font-size: 36rpx;
  color: var(--text-main);
  font-weight: 700;
  margin-left: 4rpx;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx dashed var(--border);
}

.time {
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.actions {
  display: flex;
  gap: 16rpx;
}

.btn-action {
  margin: 0;
  padding: 0 32rpx;
  height: 56rpx;
  line-height: 54rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
}

.btn-action.default {
  background: #fff;
  color: var(--text-main);
  border: 1px solid var(--border);
}

.btn-action.primary {
  background: var(--primary);
  color: #fff;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 240rpx;
  height: 240rpx;
  background: var(--bg-page);
  border-radius: 50%;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-placeholder);
}
