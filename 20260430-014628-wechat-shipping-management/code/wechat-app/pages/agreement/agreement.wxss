.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.hero {
  text-align: center;
}

.hero-title {
  display: block;
  font-size: 38rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.hero-sub {
  display: block;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.block {
  margin-top: 0;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.p {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.7;
  margin-bottom: 12rpx;
}

.footer {
  margin-bottom: 40rpx;
}
