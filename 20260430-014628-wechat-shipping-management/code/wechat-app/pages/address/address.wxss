.page {
  min-height: 100vh;
  padding-bottom: 120rpx;
}

.address-card {
  margin-bottom: 24rpx;
}

.address-card .main {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.address-card .name {
  font-size: 32rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.address-card .phone {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.default-tag {
  margin-left: 12rpx;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 6rpx;
}

.address-card .addr {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.5;
}

.address-card .actions {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid var(--border);
  font-size: 28rpx;
  color: var(--primary);
}

.address-card .actions text {
  margin-right: 32rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: var(--white);
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn-add {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 12rpx;
}
