/**app.wxss - Premium Global Style **/
page {
  --primary: #059669;
  --primary-light: #ecfdf5;
  --primary-dark: #047857;
  --primary-gradient: linear-gradient(135deg, #10b981 0%, #059669 100%);
  --text-main: #1D1D1F;
  --text-regular: #424245;
  --text-secondary: #86868B;
  --text-placeholder: #A1A1A6;
  --border: #F5F5F7;
  --bg-page: #FBFBFD;
  --bg-card: #FFFFFF;
  --white: #FFFFFF;
  --red: #FF3B30;
  --red-light: #FFEDED;

  background-color: var(--bg-page);
  color: var(--text-main);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica, 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, button, navigator {
  box-sizing: border-box;
}

/* Premium Button */
.btn-primary {
  background: var(--primary-gradient);
  color: var(--white);
  border: none;
  border-radius: 40rpx;
  font-weight: 500;
  font-size: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.25);
  transition: all 0.2s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 10rpx rgba(7, 193, 96, 0.15);
}

.btn-outline {
  background: transparent;
  color: var(--text-main);
  border: 1rpx solid var(--border);
  border-radius: 40rpx;
  font-weight: 500;
  font-size: 28rpx;
}

/* Glassmorphism Card */
.card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin: 24rpx 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.04);
}

/* Standard List Item */
.list-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 0;
  background: var(--bg-card);
  border-bottom: 1rpx solid var(--border);
}

.list-item:last-child {
  border-bottom: none;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
  color: var(--text-secondary);
  font-size: 28rpx;
}
.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

/* Layout Utilities */
.flex-row { display: flex; flex-direction: row; align-items: center; }
.flex-col { display: flex; flex-direction: column; }
.space-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.align-start { align-items: flex-start; }
.align-center { align-items: center; }
.text-ellipsis { overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.text-ellipsis-2 { display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }
.fw-500 { font-weight: 500; }
.fw-600 { font-weight: 600; }
.fs-24 { font-size: 24rpx; }
.fs-28 { font-size: 28rpx; }
.fs-32 { font-size: 32rpx; }
.fs-36 { font-size: 36rpx; }
.color-primary { color: var(--primary); }
.color-secondary { color: var(--text-secondary); }
.color-red { color: var(--red); }
