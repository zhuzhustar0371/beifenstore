DB_URL=jdbc:mysql://127.0.0.1:3306/zhixi?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_DRIVER=com.mysql.cj.jdbc.Driver
CORS_ORIGINS=https://mashishi.com,https://www.mashishi.com,https://admin.mashishi.com

# Tencent Cloud SMS
TENCENT_SMS_SECRET_ID=your_tencent_sms_secret_id
TENCENT_SMS_SECRET_KEY=your_tencent_sms_secret_key
TENCENT_SMS_SDK_APP_ID=1401108208
TENCENT_SMS_SIGN_NAME=石家庄知禧健康管理
TENCENT_SMS_TEMPLATE_ID=2625405
TENCENT_SMS_RESET_TEMPLATE_ID=
TENCENT_SMS_REGION=ap-guangzhou
SMS_CODE_EXPIRE_MINUTES=5
SMS_SKIP_VERIFY=false

# WeChat mini-program login
WECHAT_MINIAPP_APP_ID=your_miniapp_app_id
WECHAT_MINIAPP_APP_SECRET=your_miniapp_app_secret

# WeChat Open Platform website QR login
WECHAT_WEB_APP_ID=your_website_app_id
WECHAT_WEB_APP_SECRET=your_website_app_secret
WECHAT_WEB_REDIRECT_URI=https://api.mashishi.com/api/auth/wechat/callback
WECHAT_WEB_SUCCESS_REDIRECT_URI=https://mashishi.com

# WeChat Pay v3 for mini-program payment
WECHAT_PAY_MCHID=your_merchant_id
WECHAT_PAY_APPID=your_miniapp_app_id
WECHAT_PAY_API_V3_KEY=your_api_v3_key
WECHAT_PAY_SERIAL_NUMBER=your_merchant_certificate_serial_number
WECHAT_PAY_PRIVATE_KEY_PATH=/home/ubuntu/apps/backend-api/cert/apiclient_key.pem
WECHAT_PAY_NOTIFY_URL=https://api.mashishi.com/api/pay/wechat/notify
WECHAT_PAY_REFUND_NOTIFY_URL=https://api.mashishi.com/api/pay/wechat/refund/notify
# Optional: configure these when the merchant account uses WeChat Pay public key mode.
WECHAT_PAY_PUBLIC_KEY_ID=
WECHAT_PAY_PUBLIC_KEY_PATH=
WECHAT_PAY_PUBLIC_KEY_PEM=
