.container {
  min-height: 100vh;
  background-color: var(--bg-page);
  position: relative;
  overflow: hidden;
}

.pb-40 {
  padding-bottom: calc(184rpx + env(safe-area-inset-bottom));
}

.user-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 20;
  display: flex;
  flex-direction: column;
}

.user-nav-hover {
  opacity: 0.98;
}

.user-nav-highlight {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(16, 185, 129, 0.98) 0%, rgba(5, 150, 105, 0.92) 100%);
}

.user-nav-status,
.user-nav-content {
  position: relative;
  z-index: 1;
}

.user-nav-content {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 140rpx;
}

.user-nav-title {
  color: rgba(255, 255, 255, 0.96);
  font-size: 32rpx;
  line-height: 1;
  font-weight: 600;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 430rpx;
  background: var(--primary-gradient);
  border-radius: 0 0 56rpx 56rpx;
  z-index: 0;
}

.user-card {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  padding: 42rpx 40rpx 30rpx;
}

.avatar-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255, 255, 255, 0.22);
  padding: 6rpx;
  box-shadow: 0 12rpx 28rpx rgba(8, 83, 58, 0.12);
}

.avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: var(--white);
}

.info-wrap {
  flex: 1;
  min-width: 0;
  margin-left: 28rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.nickname {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.24;
  margin-bottom: 6rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.user-subline {
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 4rpx;
}

.login-tip {
  font-size: 24rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.arrow-icon {
  margin-left: 18rpx;
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.6);
}

.assets-box {
  position: relative;
  z-index: 1;
  background: var(--white);
  border-radius: 28rpx;
  margin: 10rpx 32rpx 28rpx;
  padding: 28rpx 0;
  display: flex;
  align-items: center;
  box-shadow: 0 16rpx 36rpx rgba(22, 34, 51, 0.06);
}

.asset-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.divider-left {
  position: relative;
}

.divider-left::before {
  content: '';
  position: absolute;
  left: 0;
  top: 15%;
  height: 70%;
  width: 1rpx;
  background: var(--border);
}

.asset-val {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--text-main);
  line-height: 1.1;
  margin-bottom: 10rpx;
}

.asset-label {
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--text-secondary);
}

.card-box {
  position: relative;
  z-index: 1;
  background: var(--white);
  border-radius: 28rpx;
  margin: 0 32rpx 28rpx;
  box-shadow: 0 10rpx 28rpx rgba(22, 34, 51, 0.04);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 30rpx 12rpx;
}

.grid-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 10rpx 0;
}

.grid-icon {
  width: 68rpx;
  height: 68rpx;
  margin-bottom: 14rpx;
  display: block;
  overflow: hidden;
  flex-shrink: 0;
}

.grid-icon-image {
  background: transparent;
}

.rule-icon {
  border-radius: 32rpx;
  background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
}

.grid-item text {
  font-size: 24rpx;
  line-height: 1.4;
  text-align: center;
  color: var(--text-main);
}

.menu-list {
  padding: 0;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 40rpx;
  background: var(--white);
  border-bottom: 1px solid var(--border);
}

.menu-item:last-child {
  border-bottom: none;
}

.contact-btn {
  border: none;
  background: transparent;
  border-radius: 0;
  line-height: inherit;
  font-size: inherit;
  margin: 0;
  text-align: left;
}

.contact-btn::after {
  display: none;
}

.menu-label {
  font-size: 30rpx;
  color: var(--text-main);
}

.arrow {
  color: var(--text-placeholder);
  font-size: 32rpx;
}

.logout-box {
  margin: 40rpx 40rpx 0;
}

.logout-btn {
  background: var(--white);
  color: var(--text-main);
  font-size: 30rpx;
  border-radius: 44rpx;
  box-shadow: 0 8rpx 18rpx rgba(22, 34, 51, 0.04);
}
