.liquid-tabbar-shell {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 18px);
  z-index: 999;
  pointer-events: none;
}

.liquid-tabbar-shadow {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 10rpx;
  bottom: -14rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at center, rgba(197, 206, 221, 0.34) 0%, rgba(197, 206, 221, 0.16) 54%, rgba(197, 206, 221, 0) 82%);
  filter: blur(26rpx);
  opacity: 0.92;
}

.liquid-tabbar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 128rpx;
  padding: 0 28rpx;
  border-radius: 64rpx;
  overflow: hidden;
  pointer-events: auto;
  background-color: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(243, 245, 249, 0.96);
  box-shadow:
    0 18rpx 42rpx rgba(192, 201, 216, 0.28),
    0 4rpx 12rpx rgba(216, 223, 234, 0.42),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.liquid-tabbar-highlight {
  display: none;
}

.liquid-tabbar-glow {
  display: none;
}

.liquid-tabbar-glow-left {
  display: none;
}

.liquid-tabbar-glow-right {
  display: none;
}

.tab-list {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 26rpx;
  box-sizing: border-box;
}

.tab-item {
  z-index: 2;
  width: 148rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
}

.tab-content {
  width: 148rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.tab-bubble {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 38rpx;
  background: transparent;
}

.tab-bubble-active {
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
  border: 1rpx solid rgba(245, 247, 250, 0.96);
  box-shadow:
    0 12rpx 28rpx rgba(203, 211, 224, 0.26),
    0 3rpx 8rpx rgba(223, 228, 236, 0.5),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.98);
}

.tab-bubble-shine {
  display: none;
}

.tab-icon {
  width: 38rpx;
  height: 38rpx;
}

.tab-label {
  font-size: 28rpx;
  line-height: 32rpx;
  min-height: 32rpx;
  max-width: 148rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #b1b7c3;
  letter-spacing: 0;
  transition: color 0.2s ease;
}

.tab-item-active .tab-label {
  color: #151b26;
  font-weight: 700;
}

@media screen and (max-width: 360px) {
  .liquid-tabbar-shell {
    left: 22rpx;
    right: 22rpx;
    bottom: calc(env(safe-area-inset-bottom) + 12px);
  }

  .liquid-tabbar {
    height: 116rpx;
    padding: 0 20rpx;
    border-radius: 58rpx;
  }

  .tab-list {
    padding: 0 16rpx;
  }

  .tab-item,
  .tab-content {
    width: 132rpx;
  }

  .tab-bubble {
    width: 64rpx;
    height: 64rpx;
    border-radius: 32rpx;
  }

  .tab-icon {
    width: 34rpx;
    height: 34rpx;
  }

  .tab-label {
    max-width: 132rpx;
    font-size: 24rpx;
    line-height: 28rpx;
    min-height: 28rpx;
  }
}

@media screen and (min-width: 430px) {
  .liquid-tabbar-shell {
    left: 34rpx;
    right: 34rpx;
    bottom: calc(env(safe-area-inset-bottom) + 20px);
  }

  .liquid-tabbar {
    height: 136rpx;
    padding: 0 32rpx;
    border-radius: 68rpx;
  }

  .tab-list {
    padding: 0 30rpx;
  }

  .tab-item,
  .tab-content {
    width: 160rpx;
  }

  .tab-bubble {
    width: 80rpx;
    height: 80rpx;
    border-radius: 40rpx;
  }

  .tab-icon {
    width: 40rpx;
    height: 40rpx;
  }

  .tab-label {
    max-width: 160rpx;
    font-size: 28rpx;
    line-height: 32rpx;
    min-height: 32rpx;
  }
}
