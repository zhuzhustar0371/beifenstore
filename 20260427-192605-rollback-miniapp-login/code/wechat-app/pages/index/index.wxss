.container {
  min-height: 100vh;
  background:
    linear-gradient(180deg, #ffffff 0%, #f7f9fc 260rpx, #f7f8fc 100%);
  padding: 0 28rpx calc(360rpx + env(safe-area-inset-bottom));
}

.hero-banner {
  position: relative;
  margin: 0 -28rpx 30rpx;
  overflow: hidden;
  border-radius: 0 0 64rpx 64rpx;
  background: linear-gradient(135deg, #60bc8d 0%, #4ca975 100%);
  box-shadow: 0 22rpx 46rpx rgba(76, 169, 117, 0.16);
}

.hero-banner::after {
  content: '';
  position: absolute;
  right: -120rpx;
  bottom: -140rpx;
  width: 420rpx;
  height: 420rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0) 72%);
}

.hero-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  padding: 84rpx 72rpx 96rpx;
}

.hero-tag {
  align-self: flex-start;
  min-height: 58rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 600;
}

.hero-title {
  display: block;
  margin-top: 54rpx;
  color: #ffffff;
  font-size: 68rpx;
  line-height: 1.24;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-sub {
  display: block;
  margin-top: 40rpx;
  color: rgba(255, 255, 255, 0.9);
  font-size: 26rpx;
  line-height: 1.7;
}

.content-stack {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
}

.section-title {
  position: relative;
  display: inline-block;
  padding-bottom: 10rpx;
  color: #111827;
  font-size: 58rpx;
  line-height: 1.08;
  font-weight: 700;
}

.section-title::after {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 12rpx;
  border-radius: 999rpx;
  background: #c8efe3;
}

.loading-card,
.empty-card {
  background: rgba(255, 255, 255, 0.92);
  border-radius: 32rpx;
  padding: 56rpx 32rpx;
  text-align: center;
  color: var(--text-placeholder);
  box-shadow: 0 16rpx 36rpx rgba(204, 212, 224, 0.18);
}

.product-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.product-card {
  width: 100%;
  min-width: 0;
  padding: 28rpx;
  display: flex;
  align-items: stretch;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.97);
  box-shadow:
    0 18rpx 40rpx rgba(209, 216, 229, 0.18),
    0 4rpx 10rpx rgba(224, 229, 238, 0.3);
}

.product-image-box {
  position: relative;
  width: 224rpx;
  height: 224rpx;
  border-radius: 24rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #eef2f5;
}

.product-image {
  width: 100%;
  height: 100%;
}

.tag-row {
  position: absolute;
  left: 0;
  top: 0;
  display: flex;
  align-items: center;
}

.tag-hot,
.tag-soft {
  height: 52rpx;
  padding: 0 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 700;
}

.tag-hot {
  color: #fff;
  background: #ff4b3f;
  border-radius: 0 0 18rpx 0;
}

.tag-soft {
  color: #61490b;
  background: rgba(255, 232, 173, 0.92);
  border-radius: 0 0 18rpx 18rpx;
}

.product-content {
  flex: 1;
  min-width: 0;
  margin-left: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.product-name {
  display: block;
  font-size: 38rpx;
  line-height: 1.34;
  font-weight: 700;
  color: #111827;
}

.product-desc {
  display: block;
  margin-top: 20rpx;
  font-size: 25rpx;
  line-height: 1.55;
  color: #8b9099;
}

.product-bottom {
  margin-top: 34rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.price-box {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: baseline;
}

.price-symbol {
  color: #ff4b3f;
  font-size: 30rpx;
  font-weight: 700;
}

.price-value {
  margin-left: 6rpx;
  color: #ff3d31;
  font-size: 66rpx;
  line-height: 1;
  font-weight: 700;
}

.buy-btn-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 4rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #16b384 0%, #0aa473 100%);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  line-height: 1;
  font-weight: 300;
  box-shadow: 0 12rpx 24rpx rgba(17, 178, 126, 0.22);
}

.benefits-card {
  border-radius: 36rpx;
  background: rgba(255, 255, 255, 0.97);
  padding: 34rpx;
  box-shadow:
    0 18rpx 44rpx rgba(209, 216, 229, 0.18),
    0 4rpx 10rpx rgba(224, 229, 238, 0.28);
}

.benefits-header {
  display: flex;
  align-items: center;
}

.benefits-accent {
  width: 10rpx;
  height: 48rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #0cb483 0%, #079867 100%);
}

.benefits-title {
  margin-left: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
  color: #111827;
}

.summary-card {
  margin-top: 32rpx;
  border: 1rpx solid rgba(13, 177, 128, 0.1);
  border-radius: 28rpx;
  padding: 30rpx 30rpx 28rpx;
  background: linear-gradient(180deg, #f5fbfa 0%, #ffffff 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.summary-price {
  display: block;
  color: #ff4337;
  font-size: 34rpx;
  line-height: 1.42;
  font-weight: 700;
}

.summary-desc {
  display: block;
  margin-top: 12rpx;
  color: #7e8792;
  font-size: 25rpx;
  line-height: 1.52;
}

.benefits-section {
  margin-top: 34rpx;
}

.benefits-section-title {
  display: block;
  color: #1a202c;
  font-size: 34rpx;
  line-height: 1.45;
  font-weight: 700;
}

.steps-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.step-item {
  min-height: 82rpx;
  padding: 18rpx 24rpx;
  display: flex;
  align-items: center;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #f7fbfb 0%, #f9fcfc 100%);
  border: 1rpx solid rgba(17, 179, 127, 0.06);
}

.step-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #079b6a;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.step-text {
  margin-left: 18rpx;
  color: #2a303b;
  font-size: 27rpx;
  line-height: 1.5;
  font-weight: 500;
}

.section-divider {
  height: 1rpx;
  margin-top: 28rpx;
  background: linear-gradient(90deg, rgba(230, 233, 239, 0) 0%, rgba(230, 233, 239, 0.88) 12%, rgba(230, 233, 239, 0.88) 88%, rgba(230, 233, 239, 0) 100%);
}

.share-section {
  margin-top: 28rpx;
}

.benefits-section-subtitle {
  display: block;
  margin-top: 12rpx;
  color: #8d94a0;
  font-size: 25rpx;
  line-height: 1.55;
}

.share-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 22rpx;
}

.share-item {
  display: flex;
  align-items: flex-start;
}

.share-dot {
  width: 12rpx;
  height: 12rpx;
  margin-top: 16rpx;
  margin-right: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #12a878;
}

.share-text {
  flex: 1;
  color: #364152;
  font-size: 27rpx;
  line-height: 1.7;
}

.footer-slogan {
  margin-top: 34rpx;
}

.footer-title {
  display: block;
  color: #17212b;
  font-size: 32rpx;
  line-height: 1.5;
  font-weight: 700;
}

.footer-subtitle {
  display: block;
  margin-top: 14rpx;
  color: #16936b;
  font-size: 27rpx;
  line-height: 1.6;
  font-weight: 500;
}

@media screen and (max-width: 360px) {
  .container {
    padding-left: 22rpx;
    padding-right: 22rpx;
    padding-bottom: calc(332rpx + env(safe-area-inset-bottom));
  }

  .hero-banner {
    margin-left: -22rpx;
    margin-right: -22rpx;
    border-radius: 0 0 52rpx 52rpx;
  }

  .hero-content {
    padding: 70rpx 48rpx 84rpx;
  }

  .content-stack {
    gap: 24rpx;
  }

  .section-title {
    font-size: 48rpx;
  }

  .product-card,
  .benefits-card {
    border-radius: 28rpx;
    padding: 22rpx;
  }

  .product-image-box {
    width: 184rpx;
    height: 184rpx;
    border-radius: 20rpx;
  }

  .product-content {
    margin-left: 20rpx;
  }

  .product-name,
  .benefits-title {
    font-size: 32rpx;
  }

  .hero-title {
    font-size: 54rpx;
  }

  .hero-sub {
    font-size: 23rpx;
  }

  .product-desc,
  .summary-desc,
  .benefits-section-subtitle,
  .share-text {
    font-size: 23rpx;
  }

  .price-value {
    font-size: 56rpx;
  }

  .buy-btn-icon {
    width: 70rpx;
    height: 70rpx;
    font-size: 46rpx;
  }
}

@media screen and (min-width: 430px) {
  .container {
    padding-left: 36rpx;
    padding-right: 36rpx;
    padding-bottom: calc(390rpx + env(safe-area-inset-bottom));
  }

  .hero-banner {
    margin-left: -36rpx;
    margin-right: -36rpx;
  }

  .hero-content {
    padding: 92rpx 86rpx 106rpx;
  }

  .section-title {
    font-size: 62rpx;
  }

  .product-card,
  .benefits-card {
    padding: 32rpx;
  }

  .product-image-box {
    width: 236rpx;
    height: 236rpx;
  }

  .product-name,
  .benefits-title {
    font-size: 40rpx;
  }

  .hero-title {
    font-size: 72rpx;
  }

  .price-value {
    font-size: 70rpx;
  }
}
