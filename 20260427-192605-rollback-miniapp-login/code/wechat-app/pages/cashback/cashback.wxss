.container {
  min-height: 100vh;
  background-color: var(--bg-page);
}

.pb-60 { padding-bottom: 60rpx; }

.wallet-card {
  position: relative;
  margin: 32rpx;
  height: 320rpx;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(7, 193, 96, 0.2);
}

.wallet-bg {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--primary-gradient);
  z-index: 1;
}

.wallet-content {
  position: relative;
  z-index: 2;
  padding: 40rpx;
  height: 100%;
  display: flex;
  flex-direction: column;
}

.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.title-wrap {
  order: 1;
}

.header-row > .btn-withdraw {
  order: 2;
}

.title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
}

.btn-withdraw {
  margin: 0;
  background: rgba(255,255,255,0.2);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.4);
  backdrop-filter: blur(4rpx);
  font-size: 24rpx;
  height: 56rpx;
  line-height: 54rpx;
  border-radius: 28rpx;
  padding: 0 32rpx;
}

.amount-row {
  margin-top: 24rpx;
  display: flex;
  align-items: baseline;
  color: #fff;
}

.symbol {
  font-size: 40rpx;
  font-weight: 600;
}

.amount-huge {
  font-size: 72rpx;
  font-weight: 700;
  margin-left: 8rpx;
}

.stats-row {
  margin-top: auto;
}

.stat-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.list-section {
  padding: 0 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: var(--primary);
  border-radius: 4rpx;
}

.list-card {
  background: var(--white);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02);
}

.icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  flex-shrink: 0;
}

.bg-blue { background: linear-gradient(135deg, #8fd3f4 0%, #84fab0 100%); }
.bg-green { background: linear-gradient(135deg, #fccb90 0%, #d57eeb 100%); }

.item-content {
  flex: 1;
  margin-left: 24rpx;
  display: flex;
  flex-direction: column;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 8rpx;
}

.item-time {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.item-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.item-amount {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.color-orange { color: #ff9900; }
.color-green { color: #07c160; }

.item-status {
  font-size: 22rpx;
  color: var(--text-placeholder);
}

.btn-confirm-transfer {
  margin: 14rpx 0 0;
  min-width: 136rpx;
  height: 50rpx;
  line-height: 48rpx;
  padding: 0 22rpx;
  border-radius: 25rpx;
  background: var(--primary);
  color: #fff;
  font-size: 22rpx;
  border: 0;
}

.loading-state {
  text-align: center;
  padding: 60rpx;
  color: var(--text-placeholder);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  background: var(--bg-page);
  border-radius: 50%;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-placeholder);
}
