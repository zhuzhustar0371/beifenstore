.login-container {
  min-height: 100vh;
  width: 100vw;
  position: relative;
  overflow: hidden;
  background-color: var(--bg-page);
  display: flex;
  flex-direction: column;
}

.bg-shape-1 {
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 600rpx;
  height: 600rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(5,150,105,0.15) 0%, rgba(5,150,105,0) 70%);
  z-index: 1;
}

.bg-shape-2 {
  position: absolute;
  bottom: 200rpx;
  left: -150rpx;
  width: 500rpx;
  height: 500rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(16,185,129,0.1) 0%, rgba(16,185,129,0) 70%);
  z-index: 1;
}

.content {
  position: relative;
  z-index: 2;
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 160rpx 60rpx 100rpx;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 80rpx;
}

.logo-box {
  width: 160rpx;
  height: 160rpx;
  background: var(--primary-gradient);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 40rpx rgba(5, 150, 105, 0.3);
  margin-bottom: 48rpx;
}

.logo-text {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
  font-family: serif;
}

.title {
  font-size: 52rpx;
  font-weight: 600;
  color: var(--text-main);
  margin-bottom: 24rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: var(--text-secondary);
  letter-spacing: 4rpx;
}

.auth-box {
  width: 100%;
}

.invite-input {
  width: 100%;
  height: 88rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  padding: 0 32rpx;
  border-radius: 44rpx;
  background: rgba(255, 255, 255, 0.86);
  color: var(--text-main);
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.auth-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  margin-bottom: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.no-login {
  width: 100%;
  display: block;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.cancel-btn {
  background: rgba(255, 255, 255, 0.6);
  border: 1px solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}

.agreement-wrapper {
  margin-top: 40rpx;
  width: 100%;
  align-items: flex-start;
}

.agree-radio {
  transform: scale(0.7);
  margin-right: 16rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
}

.agreement-text {
  flex: 0 1 auto;
  max-width: 460rpx;
  min-width: 0;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  justify-content: flex-start;
  font-size: 24rpx;
  color: var(--text-placeholder);
  line-height: 1.6;
  text-align: left;
}

.agreement-link {
  color: var(--primary);
  text-decoration: underline;
  margin: 0 6rpx;
}
