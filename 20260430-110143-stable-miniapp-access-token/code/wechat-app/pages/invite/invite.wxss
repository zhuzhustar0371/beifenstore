.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.tabs {
  display: flex;
  background: var(--white);
  padding: 0 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--text-secondary);
}

.tab.active {
  color: var(--primary);
  font-weight: 600;
  border-bottom: 4rpx solid var(--primary);
}

.invite-card,
.qrcode-card {
  text-align: center;
  margin-top: 24rpx;
}

.invite-card .title,
.qrcode-card .title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.invite-card .code {
  display: block;
  font-size: 48rpx;
  font-weight: 600;
  letter-spacing: 8rpx;
  color: var(--primary);
  margin-bottom: 24rpx;
}

.btn-copy {
  display: inline-block;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 28rpx;
  border-radius: 36rpx;
}

.qrcode-wrap {
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto 20rpx;
  background: var(--bg);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.qrcode {
  width: 280rpx;
  height: 280rpx;
}

.qrcode-empty {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.qrcode-status {
  font-size: 24rpx;
  color: var(--text-placeholder);
  text-align: center;
  line-height: 1.6;
}

.btn-reload {
  min-width: 180rpx;
  height: 60rpx;
  line-height: 60rpx;
  font-size: 24rpx;
  border-radius: 30rpx;
}

.qrcode-card .tip {
  display: block;
  font-size: 24rpx;
  color: var(--text-placeholder);
}

.btn-share {
  display: inline-block;
  min-width: 220rpx;
  height: 72rpx;
  line-height: 72rpx;
  margin-top: 24rpx;
  padding: 0 40rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  color: #fff;
  background: var(--primary);
}

.record-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.record-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: var(--bg);
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-item .name {
  display: block;
  font-size: 30rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-item .time {
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-top: 6rpx;
}

.record-item .tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.record-item .tag.done {
  background: #e6f7ff;
  color: #1890ff;
}

.record-item .tag.pending {
  background: #fff7e6;
  color: #fa8c16;
}
