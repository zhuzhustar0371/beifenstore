.liquid-tabbar-shell {
  position: fixed;
  left: 28rpx;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 10px);
  z-index: 999;
  pointer-events: none;
}

.liquid-tabbar-shadow {
  position: absolute;
  left: 12rpx;
  right: 12rpx;
  top: 8rpx;
  bottom: -10rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at center, rgba(197, 206, 221, 0.24) 0%, rgba(197, 206, 221, 0.1) 54%, rgba(197, 206, 221, 0) 82%);
  filter: blur(20rpx);
  opacity: 0.78;
}

.liquid-tabbar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 112rpx;
  padding: 0 22rpx;
  border-radius: 56rpx;
  overflow: hidden;
  pointer-events: auto;
  background-color: rgba(255, 255, 255, 0.96);
  border: 1rpx solid rgba(243, 245, 249, 0.96);
  box-shadow:
    0 12rpx 28rpx rgba(192, 201, 216, 0.22),
    0 3rpx 10rpx rgba(216, 223, 234, 0.28),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.92);
}

.liquid-tabbar-highlight {
  display: none;
}

.liquid-tabbar-glow {
  display: none;
}

.liquid-tabbar-glow-left {
  display: none;
}

.liquid-tabbar-glow-right {
  display: none;
}

.tab-list {
  position: relative;
  z-index: 2;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.tab-item {
  z-index: 2;
  width: 136rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  box-sizing: border-box;
}

.tab-content {
  width: 136rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.tab-bubble {
  position: relative;
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 34rpx;
  background: transparent;
}

.tab-bubble-active {
  background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
  border: 1rpx solid rgba(245, 247, 250, 0.96);
  box-shadow:
    0 8rpx 18rpx rgba(203, 211, 224, 0.22),
    0 2rpx 6rpx rgba(223, 228, 236, 0.4),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.98);
}

.tab-bubble-shine {
  display: none;
}

.tab-icon {
  width: 34rpx;
  height: 34rpx;
}

.tab-label {
  font-size: 24rpx;
  line-height: 28rpx;
  min-height: 28rpx;
  max-width: 136rpx;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  color: #b1b7c3;
  letter-spacing: 0;
  transition: color 0.2s ease;
}

.tab-item-active .tab-label {
  color: #151b26;
  font-weight: 700;
}

@media screen and (max-width: 360px) {
  .liquid-tabbar-shell {
    left: 22rpx;
    right: 22rpx;
    bottom: calc(env(safe-area-inset-bottom) + 8px);
  }

  .liquid-tabbar {
    height: 102rpx;
    padding: 0 16rpx;
    border-radius: 51rpx;
  }

  .tab-list {
    padding: 0 12rpx;
  }

  .tab-item,
  .tab-content {
    width: 120rpx;
  }

  .tab-bubble {
    width: 58rpx;
    height: 58rpx;
    border-radius: 29rpx;
  }

  .tab-icon {
    width: 30rpx;
    height: 30rpx;
  }

  .tab-label {
    max-width: 120rpx;
    font-size: 22rpx;
    line-height: 26rpx;
    min-height: 26rpx;
  }
}

@media screen and (min-width: 430px) {
  .liquid-tabbar-shell {
    left: 34rpx;
    right: 34rpx;
    bottom: calc(env(safe-area-inset-bottom) + 12px);
  }

  .liquid-tabbar {
    height: 118rpx;
    padding: 0 26rpx;
    border-radius: 59rpx;
  }

  .tab-list {
    padding: 0 22rpx;
  }

  .tab-item,
  .tab-content {
    width: 146rpx;
  }

  .tab-bubble {
    width: 72rpx;
    height: 72rpx;
    border-radius: 36rpx;
  }

  .tab-icon {
    width: 36rpx;
    height: 36rpx;
  }

  .tab-label {
    max-width: 146rpx;
    font-size: 25rpx;
    line-height: 29rpx;
    min-height: 29rpx;
  }
}
