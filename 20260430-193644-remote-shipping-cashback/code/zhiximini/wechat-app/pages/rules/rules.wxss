.page {
  min-height: 100vh;
  padding-bottom: 32rpx;
}

.content {
  margin-bottom: 24rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.p {
  display: block;
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.table-wrap {
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  overflow: hidden;
  margin: 16rpx 0;
}

.row {
  display: flex;
  border-bottom: 1rpx solid var(--border);
  font-size: 26rpx;
}

.row:last-child {
  border-bottom: none;
}

.row.head {
  background: var(--bg);
  font-weight: 600;
}

.row .col {
  flex: 1;
  padding: 20rpx 16rpx;
  text-align: center;
}

.row .col:first-child {
  text-align: left;
}

.status {
  margin: 20rpx 24rpx 0;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.status.error {
  color: #d64545;
}
